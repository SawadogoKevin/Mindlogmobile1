<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    android:orientation="vertical">

    <!-- Toolbar Épurée -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?android:attr/actionBarSize"
        android:background="#F8F9FA"
        app:navigationIcon="?android:attr/homeAsUpIndicator"
        app:title="Signaler une panne"
        app:titleTextColor="#1A1A1A"
        app:titleTextAppearance="@style/TextAppearance.MaterialComponents.Headline6" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:overScrollMode="never"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Fiche résumé Matériel succincte -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/tile_icon_bg"
                android:backgroundTint="#0d000000"
                android:orientation="vertical"
                android:padding="14dp"
                android:layout_marginBottom="20dp"
                app:cornerRadius="12dp"> <!-- Note : Si tile_icon_bg ne supporte pas le cornerRadius en direct, un petit layout arrondi en xml est idéal -->

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Matériel concerné"
                    android:textColor="#757575"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/materielIdText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="ID"
                    android:textColor="#1A1A1A"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Bannière d'erreur moderne -->
            <TextView
                android:id="@+id/errorBanner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:background="#FFEBEE"
                android:padding="14dp"
                android:textColor="#C62828"
                android:textSize="14sp"
                android:visibility="gone" />

            <!-- Champ de description Modernisé -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Description de la panne"
                app:boxStrokeColor="#FFB300"
                app:hintTextColor="#FFB300"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/descriptionInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="top"
                    android:inputType="textMultiLine"
                    android:minLines="4"
                    android:textColor="#1A1A1A"
                    android:textSize="15sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Section Type de panne -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Type de panne"
                android:textColor="#1A1A1A"
                android:textStyle="bold"
                android:textSize="14sp" />

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/typeToggleGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                app:singleSelection="true"
                app:checkedButton="@id/buttonReparable">

                <Button
                    android:id="@+id/buttonReparable"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="Réparable"
                    app:strokeColor="#FFB300" />

                <Button
                    android:id="@+id/buttonNonReparable"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="Non réparable"
                    app:strokeColor="#FFB300" />
            </com.google.android.material.button.MaterialButtonToggleGroup>

            <!-- Section Média / Photo -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="Justificatifs (photo caméra ou galerie)"
                android:textColor="#1A1A1A"
                android:textStyle="bold"
                android:textSize="14sp" />

            <!-- Liste des photos sélectionnées -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerViewPhotos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

            <!-- Boutons d'action Média -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/cameraButton"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:text="Caméra"
                    android:textColor="#FFB300"
                    app:icon="@android:drawable/ic_menu_camera"
                    app:iconTint="#FFB300"
                    app:strokeColor="#FFB300"
                    app:cornerRadius="12dp" />

                <Button
                    android:id="@+id/galleryButton"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:text="Galerie"
                    android:textColor="#FFB300"
                    app:icon="@android:drawable/ic_menu_gallery"
                    app:iconTint="#FFB300"
                    app:strokeColor="#FFB300"
                    app:cornerRadius="12dp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Bouton Soumission Principal -->
    <Button
        android:id="@+id/submitButton"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_margin="20dp"
        android:backgroundTint="#FFB300"
        android:text="Signaler la panne"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        app:cornerRadius="14dp" />

</LinearLayout>