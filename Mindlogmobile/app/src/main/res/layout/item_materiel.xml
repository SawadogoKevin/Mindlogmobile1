<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp">

        <View
            android:id="@+id/iconBg"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/tile_icon_bg" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/materielTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Marque Modèle"
                android:textColor="#000000"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/materielType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Type"
                android:textColor="#757575"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/materielId"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ID"
                android:textColor="#757575"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/etatBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#1A4CAF50"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:text="Bon"
            android:textColor="#4CAF50"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>
</androidx.cardview.widget.CardView>
